{
  "model": "claude-opus-4-6",
  "teammateMode": "in-process",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git worktree*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(ls*)",
      "Bash(cat domain-config.yaml)",
      "Bash(cat team-config.yaml)",
      "Agent(cto-agent)",
      "Agent(coo-agent)",
      "Agent(cmo-agent)",
      "Agent(code-reviewer)",
      "Agent(debugger)",
      "Agent(Explore)",
      "Agent(Plan)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(git clean -f*)"
    ]
  }
}
